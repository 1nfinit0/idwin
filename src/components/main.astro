---
import Hero from '@components/subcomponents/hero.astro';
import Slider from '@components/subcomponents/slider.astro';
import CatalogCategory from '@components/subcomponents/CatalogCategory.astro';
---
<main class="flex flex-col items-center bg-primary">
  <div class="w-full bg-(image:--gradient-main)">
    <Hero />
  </div>
  <div class="w-full max-w-6xl">
    <p class="text-text py-8 px-10 font-extralight text-xl md:text-3xl">
      Explora nuestros productos
    </p>
  </div>
  <div class="w-full max-w-6xl px-6 md:px-10 flex items-center justify-center my-8">
    <Slider />
  </div>
  <div class="w-full max-w-4xl flex justify-end my-2 mt-4 flex-col">
    <p class="text-text px-10 font-extralight text-md md:text-xl">
    Lo más pedido 🔥
    </p>
  </div>
  <div class="w-full max-w-4xl px-4 flex items-center justify-center">
    <CatalogCategory />
  </div>
</main>