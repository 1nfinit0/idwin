---
import Hero from '@components/subcomponents/hero.astro';
import Slider from '@components/subcomponents/Slider.astro';
import CatalogCategory from '@components/subcomponents/CatalogCategory.astro';
import items from "@data/rawCarousel.json";
---
<main class="flex flex-col items-center bg-primary">
  <div class="w-full bg-(image:--gradient-main)">
    <Hero />
  </div>
  <div class="w-full max-w-6xl">
    <p class="text-text py-8 px-10 font-extralight text-xl md:text-3xl">
      Explora nuestros productos
    </p>
  </div>
  <div class="w-full p-4 flex justify-center ">
    <div class="w-full max-w-5xl flex flex-col items-center justify-center bg-secondary rounded-2xl">
      <Slider>
        {
        items.map((item) => (
          <div class=" w-full h-100 shrink-0 flex items-center justify-center snap-center relative">

              <p class="absolute top-2 left-2 text-text-feature text-4xl font-bold z-20 text-shadow-md text-shadow-white/50 m-4">{item.nombre}</p>

            <model-viewer
              src={item.src}
              environment-image="/hdri/ferndale_studio_04_1k.hdr"
              shadow-intensity="1"
              camera-controls
              auto-rotate
              class="w-full h-full"
              camera-orbit="180deg 90deg m"
            ></model-viewer>

            <a href={`/builder?category=${item.index}`} class="absolute bottom-2 right-2 rounded-2xl bg-primary text-text px-4 py-2 hover:bg-primary/50 m-4">Ver toda la familia del {item.nombre}</a>

          </div>
        ))
      }
      </Slider>
    </div>
  </div>
  <div class="w-full max-w-4xl flex justify-end my-2 mt-4 flex-col">
    <p class="text-text px-10 font-extralight text-md md:text-xl">
    Lo más pedido 🔥
    </p>
  </div>
  <div class="w-full max-w-5xl px-4 flex justify-end">
    <CatalogCategory />
  </div>
</main>