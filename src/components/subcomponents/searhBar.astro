---
import productos from "@data/rawData.json";

// Solo productos públicos
const productosPublicos = productos.filter(p => p.estado === "Público");
---

<div 
  class="w-full p-2 md:p-4 bg-primary relative flex justify-center"
  data-productos={JSON.stringify(productosPublicos)}
  id="searchWrapper"
>
  <input
    type="text"
    id="searchInput"
    placeholder="Buscar iPhone (ej: 14 pro 256 silver)"
    class="w-full max-w-3xl text-text p-2 md:p-6 rounded-2xl border border-gost-hover
           focus:outline-none focus:ring-2 focus:ring-secondary
           transition shadow-sm"
  />
  <button
      id="clearSearch"
      class="absolute right-5 top-1/2 -translate-y-1/2 text-text/50 hover:text-gost-hover transition
             focus:outline-none hidden text-xl font-medium"
      aria-label="Limpiar búsqueda"
    >
      x
    </button>
  <div id="results" class="absolute w-dvw max-w-3xl px-2 mt-15 z-20"></div>
</div>

<script>
  const wrapper = document.getElementById("searchWrapper");
  const productos = wrapper ? JSON.parse(wrapper.dataset.productos || "[]") : [];

  const input = document.getElementById("searchInput");
  const clearButton = document.getElementById("clearSearch");
  const results = document.getElementById("results");

  const MAX_RESULTS = 5;


  function normalize(text: any) {
    return text
      ?.toString()
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "") || "";
  }

  // Función para mostrar/ocultar el botón de limpiar
  function toggleClearButton() {
    if (input && clearButton) {
      if ((input as HTMLInputElement).value.length > 0) {
        clearButton.classList.remove('hidden');
      } else {
        clearButton.classList.add('hidden');
      }
    }
  }

  // Limpiar el input
  function clearSearch() {
    if (input) {
      (input as HTMLInputElement).value = '';
      input.dispatchEvent(new Event('input'));
      toggleClearButton();
      input.focus();
    }
  }

  if (input) {
    // Evento para mostrar/ocultar el botón mientras se escribe
    input.addEventListener('input', (e) => {
      toggleClearButton();
      
      const target = e.target as HTMLInputElement | null;
      const query = normalize(target ? target.value : "");

      if (!results) return;
      results.innerHTML = "";
      if (!query) return;

      const filtrados = productos.filter((producto: { producto: any; categoria: any; modelo: any; color: any; almacenamiento: any; }) => {
        const searchable = [
          producto.producto,
          producto.categoria,
          producto.modelo,
          producto.color,
          producto.almacenamiento
        ]
          .map(normalize)
          .join(" ");

        return searchable.includes(query);
      }).slice(0, MAX_RESULTS);

      if (filtrados.length === 0) {
        results.innerHTML =
          '<p class="text-gray-500 text-sm">No se encontraron resultados</p>';
        return;
      }

      filtrados.forEach((producto: { producto: any; almacenamiento: any; color: any; modelo: any; precio: any; }) => {
        const div = document.createElement("div");
        div.className =
          "p-3 rounded-2xl bg-gost shadow hover:gost-hover transition my-2 cursor-pointer";

        div.innerHTML = `
          <div class="font-semibold text-lg text-text">
            ${producto.producto}
          </div>
          <div class="text-sm text-text-secondary mt-1">
            ${producto.almacenamiento} • ${producto.color} • ${producto.modelo}
          </div>
          <div class="mt-2 font-bold text-text-feature">
            $${producto.precio}
          </div>
        `;

        results.appendChild(div);
      });
    });

    // Verificar estado inicial (por si hay valor precargado)
    toggleClearButton();
  }

  if (clearButton) {
    clearButton.addEventListener('click', clearSearch);
  }
</script>