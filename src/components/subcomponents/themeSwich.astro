---

---
<div class="flex items-center justify-center">
  <button
    id="theme-toggle"
    onclick="toggleTheme()"
    class="relative w-16 h-9 rounded-full 
           bg-gost
           border border-gost-hover
           transition-all duration-300 ease-in-out
           flex items-center px-1"
  >
    <span
      id="icon-light"
      class="absolute left-2 text-yellow-400 text-sm transition-opacity duration-300 z-20"
    >
      🌙
    </span>

    <span
      id="icon-dark"
      class="absolute right-2 text-blue-400 text-sm transition-opacity duration-300 opacity-0 z-20"
    >
      ☀️
    </span>

    <span
      id="switch-circle"
      class="w-7 h-7 rounded-full 
             bg-secondary
             shadow-md
             transform transition-all duration-300 ease-in-out z-10"
    ></span>
  </button>
</div>
<script is:inline>
  function toggleTheme() {
    const root = document.documentElement;
    const circle = document.getElementById("switch-circle");
    const iconLight = document.getElementById("icon-light");
    const iconDark = document.getElementById("icon-dark");

    const isDark = root.classList.toggle("theme-dark");

    if (isDark) {
      circle.classList.add("translate-x-7");
      iconLight.classList.add("opacity-0");
      iconDark.classList.remove("opacity-0");
    } else {
      circle.classList.remove("translate-x-7");
      iconLight.classList.remove("opacity-0");
      iconDark.classList.add("opacity-0");
    }
  }
</script>
