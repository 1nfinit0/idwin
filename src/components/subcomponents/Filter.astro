---
interface Props<T> {
  items: T[];
  filters: (keyof T)[];
}

const { items, filters } = Astro.props as Props<Record<string, any>>;
---

<div
  class="filter-component w-full flex flex-col gap-4 items-center justify-center p-4"
  id="filterWrapper"
  data-items={JSON.stringify(items)}
  data-filters={JSON.stringify(filters)}
>
  <div class="flex flex-col gap-6">
    {
      filters.map((filterKey) => {
        const values = [...new Set(items.map((item) => item[filterKey]))];

        return (
          <div class="flex flex-col items-center gap-2">
            <h3 class="text-lg font-semibold capitalize text-text">
              {String(filterKey)}
            </h3>

            <div
              class="flex gap-2 flex-wrap justify-center filter-group p-4"
              data-filter={String(filterKey)}
            >
              {values.map((value) => (
                <button
                  type="button"
                  class="filter-btn px-8 py-2 rounded-xl border border-transparent bg-secondary text-text transition"
                  data-value={String(value)}
                >
                  {String(value)}
                </button>
              ))}
            </div>
          </div>
        );
      })
    }
  </div>

  <div class="results max-w-6xl flex flex-wrap items-center justify-around gap-6 text-text m-8"></div>
</div>
<script>
  const params = new URLSearchParams(window.location.search);
  const category = Number(params.get("category"));

  const indexList = [13, 13, 14, 15, 16, 17];
  const versionDefault = indexList[category] || 13;

  const wrapper = document.getElementById("filterWrapper");

  const items = wrapper ? JSON.parse(wrapper.dataset.items || "[]") : [];

  const filters = wrapper ? JSON.parse(wrapper.dataset.filters || "[]") : [];

  const resultsDiv = wrapper?.querySelector(".results");
  const groups = wrapper?.querySelectorAll(".filter-group");

  function renderResults(filtered: any[]) {
  if (!resultsDiv) return;

  resultsDiv.innerHTML = "";

  if (filtered.length === 0) {
    resultsDiv.innerHTML = `
      <div class="col-span-3 text-center py-6">
        No existe el producto
      </div>
    `;
    return;
  }

  filtered.forEach((item) => {
    const card = document.createElement("a");

    card.href = `/iphone/${item.id}`;
    card.className = `
      card min-w-60 max-w-60 rounded-lg shadow-lg
      flex flex-col items-center justify-between
      bg-primary border border-text/50
      transition hover:scale-105 hover:shadow-xl
    `;

    card.innerHTML = `
      <img 
        src="${item.image1}" 
        alt="${item.version}" 
        class="w-full aspect-square object-cover rounded-t-lg"
      />

      <div class="info w-full h-full px-3 py-3 flex flex-col justify-between gap-3">
        
        <p class="text-text text-lg font-light text-center">
          iPhone ${item.version} ${item.modelo}
        </p>

        <div class="w-full flex justify-around text-sm">
          
          <div class="w-20 flex flex-col items-center">
            <img src="/icons/storage.svg" 
                 class="w-4 h-4 invert-50 mb-1" />
            <p class="text-text-secondary">
              ${item.capacidad}
            </p>
          </div>

          <div class="w-20 flex flex-col items-center">
            <img src="/icons/heart.svg" 
                 class="w-4 h-4 invert-50 mb-1" />
            <p class="text-text-secondary">
              ${item.estado}
            </p>
          </div>

        </div>

        <div class="flex flex-col items-center gap-1">
          ${
            item.precioAntes
              ? `<p class="text-sm text-text-secondary line-through">
                   S/. ${item.precioAntes}
                 </p>`
              : ""
          }

          <p class="text-text-feature font-bold text-xl">
            S/. ${item.precio}
          </p>
        </div>

      </div>
    `;

    resultsDiv.appendChild(card);
  });
}

  function applyFilters() {
    if (!groups) return;

    const activeFilters: Record<string, string> = {};

    groups.forEach((group) => {
      const key = (group as HTMLElement).dataset.filter;
      const activeBtn = group.querySelector(".active") as HTMLElement;

      if (key && activeBtn) {
        const value = activeBtn.dataset.value;
        if (value) activeFilters[key] = value;
      }
    });

    const filtered = items.filter((item: { [x: string]: any }) =>
      Object.entries(activeFilters).every(
        ([key, value]) => String(item[key]) === String(value),
      ),
    );

    renderResults(filtered);
  }

  // 🔥 Manejo visual de botones
  groups?.forEach((group) => {
  const buttons = group.querySelectorAll(".filter-btn");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {

      // quitar activo del grupo
      buttons.forEach((b) => {
        b.classList.remove("active", "border-text-feature");
        b.classList.add("border-transparent");
      });

      // activar solo el borde
      btn.classList.add("active", "border-text-feature");
      btn.classList.remove("border-transparent");

      applyFilters();
    });
  });
});

  // 🔥 Aplicar versión por defecto
  if (!isNaN(category) && groups) {
  groups.forEach((group) => {
    const key = (group as HTMLElement).dataset.filter;

    if (key === "version") {
      const buttons = group.querySelectorAll(".filter-btn");

      // limpiar grupo primero
      buttons.forEach((b) => {
        b.classList.remove("active", "border-text-feature");
        b.classList.add("border-transparent");
      });

      const btn = group.querySelector(
        `[data-value="${String(versionDefault)}"]`
      );

      if (btn) {
        btn.classList.add("active", "border-text-feature");
        btn.classList.remove("border-transparent");
      }
    }
  });
}

  applyFilters();
</script>
