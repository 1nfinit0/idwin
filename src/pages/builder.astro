---
import Layout from '@layouts/Layout.astro';
import Header from '@components/header.astro';
import Footer from '@components/footer.astro';
import products from '@data/rawData.json';
import items from "@data/rawCarousel.json";
import Slider from '@components/subcomponents/Slider.astro';
import Filter from '@components/subcomponents/Filter.astro';
---

<Layout title={"iDwin - Builder"}>
  <Header />
  <main class="w-full px-4 bg-primary flex flex-col items-center">
    <div class="w-full max-w-6xl">
      <Slider>
        {
        items.map((item) => (
          <div class=" w-full h-100 shrink-0 flex items-center justify-center snap-center relative">
            <p class="absolute top-2 left-2 text-text-feature text-4xl font-bold z-20 text-shadow-md text-shadow-white/50 m-4">{item.nombre}</p>
            <model-viewer
              src={item.src}
              environment-image="/hdri/ferndale_studio_04_1k.hdr"
              shadow-intensity="1"
              camera-controls
              auto-rotate
              class="w-full h-full"
              camera-orbit="180deg 90deg m"
            ></model-viewer>
          </div>
        ))
      }
      </Slider>
    </div>
    <Filter
  items={products}
  filters={["version", "modelo", "estado"]}
/>
  </main>
  <Footer />
</Layout>
<script>
  const params = new URLSearchParams(window.location.search);
  const category = params.get("category");
</script>